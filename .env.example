# Supabase Postgres Connection URL (Use connection pooling URL usually, or direct connection URL)
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Supabase API Settings (Found in Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Application Configuration
PORT=8000
FRONTEND_ORIGIN=http://127.0.0.1:8000
